{
  "manifest_version": 3,
  "name": "Type Quest - Typing Practice for Kids",
  "version": "1.0.0",
  "description": "A fun typing game for kids! Practice typing words as they fall from the sky.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": ["storage"]
}
